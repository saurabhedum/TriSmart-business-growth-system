rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // GLOBAL HELPERS & CONSTANTS
    // =========================================================================
    
    function isSignedIn() { return request.auth != null; }
    function isOwner(data) { return isSignedIn() && data.ownerId == request.auth.uid; }
    function isAdmin() { 
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'saurabh.trismart@gmail.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // =========================================================================
    // COLLECTION RULES
    // =========================================================================

    match /leads/{leadId} {
      allow read: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin(); // Changed to explicit conditions
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if (isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin())) || 
                       incoming().diff(existing()).affectedKeys().hasOnly(['householdMembers']);
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /conversions/{conversionId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }
    
    match /interactions/{interactionId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }
    
    match /social_accounts/{accountId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }
    
    match /marketing_campaigns/{campaignId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }
    
    match /automation_audit/{auditId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /settings/{userId} {
      allow read: if (isSignedIn() && userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && userId == request.auth.uid;
      allow update: if (isSignedIn() && userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /inventory_categories/{categoryId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /inventory_items/{itemId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /inventory_orders/{orderId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /agent_modules/{moduleId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /uploadedData/{uploadId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /whatsapp_messages/{messageId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && (incoming().ownerId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if true; // Public viewable via portal (get and list)
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isOwner(existing()) || isAdmin();
      allow delete: if isOwner(existing()) || isAdmin();
    }

    match /chatbot_settings/{userId} {
      allow read: if true; // Webhook needs access
      allow write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
    }

    match /providers/{providerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /automation_errors/{errorId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if true; // Server logs these
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /quotations/{quotationId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /expenses/{expenseId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /tickets/{ticketId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /goals/{goalId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /rewards/{rewardId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }
    
    match /employee_communications/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /warehouses/{warehouseId} {
      allow read: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    match /forms/{formId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /test/{docId} {
      allow read, write: if true;
    }
  }
}
